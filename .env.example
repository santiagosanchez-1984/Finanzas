# Google Cloud — Service Account para leer/escribir la planilla
GOOGLE_CLIENT_EMAIL=nombre@tu-proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY_ID=...
# Private key completa en base64 (evita problemas de saltos de linea en .env)
# Generarla con: node -e "console.log(Buffer.from(require('./key.json').private_key).toString('base64'))"
GOOGLE_PRIVATE_KEY=...

# ID de la planilla de Google Sheets
SHEET_ID=tu_sheet_id_aqui

# Login (usuario/clave compartido)
AUTH_USER=usuario
AUTH_PASS=clave
AUTH_SECRET=una_clave_secreta_random_larga
