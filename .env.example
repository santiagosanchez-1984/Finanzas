# Google Cloud — Service Account para leer/escribir la planilla
GOOGLE_CLIENT_EMAIL=nombre@tu-proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY_ID=...
# Private key completa en base64 (evita problemas de saltos de linea en .env)
# Generarla con: node -e "console.log(Buffer.from(require('./key.json').private_key).toString('base64'))"
GOOGLE_PRIVATE_KEY=...

# ID de la planilla de Google Sheets
SHEET_ID=tu_sheet_id_aqui

# Login con Google (OAuth2) — mismo patron que el proyecto COA
AUTH_SECRET=una_clave_secreta_random_larga
GOOGLE_CLIENT_ID=obtener-en-console.cloud.google.com
GOOGLE_CLIENT_SECRET=obtener-en-console.cloud.google.com
# Primer usuario (admin) sembrado automaticamente en la hoja "Usuarios" la
# primera vez que alguien intenta loguearse y la hoja esta vacia.
ADMIN_EMAIL=tu-email@gmail.com
ADMIN_NOMBRE=Tu Nombre

# Modulo Facturas IVA — Gemini API (gratis, generar en https://aistudio.google.com/apikey)
GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-flash-lite-latest

# ID de la carpeta de Drive con las facturas (compartida como Lector con
# GOOGLE_CLIENT_EMAIL de arriba). Es el segmento despues de /folders/ en la URL.
FACTURAS_DRIVE_FOLDER_ID=tu_folder_id_aqui
